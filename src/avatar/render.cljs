(defn make-brow
  "Create a brow renderer from one normalized SVG element."
  [element]
  (fn brow-renderer [{:keys [color]}]
    (asset-root
     (let [[tag attrs] element]
       [tag (assoc attrs :fill (or color "black"))]))))

