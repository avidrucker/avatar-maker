(defn make-nose
  [{:keys [path black-path shade-path preview-path preview-view-box preview-transform]}]
  (let [render-fn
        (fn nose-renderer [{:keys [mode skin fill]}]
          (if (= mode :preview)
            [:path {:d (or preview-path black-path path)
                    :fill (or fill "black")}]
            (asset-root
             (when shade-path
               (head-fill-node shade-path skin))
             [:path {:d (or black-path path)
                     :fill "black"}])))]
    (with-meta render-fn
      {:preview/view-box (or preview-view-box "0 0 100 100")
       :preview/transform (or preview-transform (when-not preview-path "translate(50 50)"))})))

