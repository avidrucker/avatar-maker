(defn make-hair
  [{:keys [front front2 back]}]
  (fn hair-renderer [{:keys [color]}]
    {:front
     (when front
       (asset-root
        [:path {:d front :fill color}]))

     :front2
     (when front2
       (asset-root
        [:path {:d front2 :fill color}]))

     :back
     (when back
       (asset-root
        [:path {:d back :fill color}]))}))

